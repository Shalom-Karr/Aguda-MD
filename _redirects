# Cloudflare Pages and Netlify automatically serve `/foo.html` at `/foo`.
# No rewrite rules are needed for clean URLs to .html files.
#
# Note: clean URLs for /posts/<slug> are handled by functions/posts/[slug].js
# rather than a _redirects rewrite, because Cloudflare Pages' built-in
# .html-stripping conflicts with rewrites whose source path overlaps an
# existing .html file (here, /posts.html).
